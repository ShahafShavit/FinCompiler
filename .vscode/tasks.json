{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Tests: all (unittest discover)",
      "type": "shell",
      "command": ".venv/bin/python -m unittest discover -s tests -p \"test_*.py\" -v || python3 -m unittest discover -s tests -p \"test_*.py\" -v",
      "windows": {
        "options": {
          "cwd": "${workspaceFolder}",
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          },
          "env": {
            "PYTHONPATH": "${workspaceFolder}\\app\\backend"
          }
        },
        "command": "if exist .venv\\Scripts\\python.exe (.venv\\Scripts\\python.exe -m unittest discover -s tests -p \"test_*.py\" -v) else (python -m unittest discover -s tests -p \"test_*.py\" -v)"
      },
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}/app/backend"
        }
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    {
      "label": "Web (Python): control server (start / restart)",
      "detail": "Free port 8780 if held, then run api with PYTHONPATH=app/backend (serves APIs + built SPA at /).",
      "type": "shell",
      "command": ".venv/bin/python app/backend/scripts/api_server_restart.py || python3 app/backend/scripts/api_server_restart.py",
      "windows": {
        "options": {
          "cwd": "${workspaceFolder}",
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          },
          "env": {
            "PYTHONPATH": "${workspaceFolder}\\app\\backend"
          }
        },
        "command": "if exist .venv\\Scripts\\python.exe (.venv\\Scripts\\python.exe app\\backend\\scripts\\api_server_restart.py) else (python app\\backend\\scripts\\api_server_restart.py)"
      },
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}/app/backend"
        }
      },
      "group": "none",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "group": "web-dev"
      },
      "problemMatcher": {
        "owner": "web-control",
        "pattern": [
          { "regexp": "^(.*)$", "file": 1, "location": 1, "message": 1 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "freeing port|Using Python:",
          "endsPattern": "Listening on http://"
        }
      }
    },

    {
      "label": "Web (SPA): npm install",
      "detail": "Install or update app/frontend deps. Run after package.json changes.",
      "type": "shell",
      "command": "npm install --no-fund --no-audit",
      "options": {
        "cwd": "${workspaceFolder}/app/frontend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Web (SPA): build",
      "detail": "TypeScript check + Vite production build into app/frontend/dist.",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/app/frontend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Web (SPA): dev (Vite, http://127.0.0.1:5173)",
      "detail": "Vite dev server with HMR; proxies API routes to Python on :8780.",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/app/frontend"
      },
      "isBackground": true,
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "group": "web-dev"
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": [
          { "regexp": "^(.*)$", "file": 1, "location": 1, "message": 1 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE v|building for|optimized dependencies",
          "endsPattern": "ready in \\d+\\s?m?s|Local:\\s+http"
        }
      }
    },

    {
      "label": "Web: kill dev ports (8780 + 5173)",
      "detail": "Stop listeners on 8780 (Python control) and 5173 (Vite).",
      "type": "shell",
      "command": "for p in 8780 5173; do lsof -ti :$p 2>/dev/null | xargs -r kill -9 2>/dev/null || true; done; echo 'Freed ports 8780 + 5173'",
      "windows": {
        "options": {
          "cwd": "${workspaceFolder}",
          "shell": {
            "executable": "powershell.exe",
            "args": ["-NoProfile", "-NonInteractive", "-Command"]
          }
        },
        "command": "foreach ($p in @(8780, 5173)) { $c = Get-NetTCPConnection -LocalPort $p -State Listen -ErrorAction SilentlyContinue; if ($null -ne $c) { $c | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue } } }; Write-Host 'Freed ports 8780 + 5173'"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },

    {
      "label": "Web: full dev (start Python + Vite)",
      "detail": "Start Python control server and Vite together; open http://127.0.0.1:5173/",
      "dependsOn": [
        "Web (Python): control server (start / restart)",
        "Web (SPA): dev (Vite, http://127.0.0.1:5173)"
      ],
      "dependsOrder": "parallel",
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "group": "web-dev"
      },
      "problemMatcher": []
    },
    {
      "label": "Web: full dev (restart all)",
      "detail": "Free 8780 + 5173, then start Python + Vite.",
      "dependsOn": [
        "Web: kill dev ports (8780 + 5173)",
        "Web: full dev (start Python + Vite)"
      ],
      "dependsOrder": "sequence",
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "group": "web-dev"
      },
      "problemMatcher": []
    }
  ]
}
