# Copy this file to `.env` in the repo root for non-secret operational settings.
# `.env` is gitignored — never commit real tokens.
#
# python-dotenv loads `.env` when `app/backend/config` is imported (see `load_dotenv()`).
#
# Bank / Max / Isracard / Google Sheets credentials are NOT configured here anymore.
# Use the web UI: Settings → Providers (writes data/private/providers.json).
# One-time migration from legacy env vars:
#   PYTHONPATH=app/backend python -m providers
#   (or "Import from .env" on the Settings page)

# ---------------------------------------------------------------------------
# Workspace & HTTP server
# ---------------------------------------------------------------------------
# Optional: root directory that contains `data/` and `web/` instead of the repo cwd.
# FINANCE_WORKSPACE_ROOT=

FINANCE_CONTROL_HTTP_HOST=127.0.0.1
FINANCE_CONTROL_HTTP_PORT=8780

# ---------------------------------------------------------------------------
# Sheet tab titles (optional overrides)
# ---------------------------------------------------------------------------
# FINANCE_TOTALS_SHEET_NAME=Totals
# FINANCE_DESKTOP_HOLDINGS_SHEET=
# FINANCE_DESKTOP_TOTALS_SHEET=

# ---------------------------------------------------------------------------
# Pipeline & Selenium debugging (optional)
# ---------------------------------------------------------------------------
# Mirror legacy cleaned CSVs under pipeline dirs for inspection.
# PIPELINE_DEBUG_DUMP=0

# Verbose Selenium steps; pause after each flow_debug_pause (1/true/yes).
# FINANCE_SELENIUM_DEBUG=0
# FINANCE_SELENIUM_PAUSE=0

# ---------------------------------------------------------------------------
# Dev helpers (optional)
# ---------------------------------------------------------------------------
# Python executable for api_server_restart.py when not using default venv discovery.
# FINANCE_PYTHON_EXE=
