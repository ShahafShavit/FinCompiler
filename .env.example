# Copy this file to `.env` in the repo root and fill in your values.
# `.env` is gitignored — never commit real credentials or tokens.
#
# python-dotenv loads `.env` when `app/backend/config` is imported (see `load_dotenv()`).

# ---------------------------------------------------------------------------
# Workspace & HTTP server
# ---------------------------------------------------------------------------
# Optional: root directory that contains `data/` and `web/` instead of the repo cwd.
# FINANCE_WORKSPACE_ROOT=

FINANCE_CONTROL_HTTP_HOST=127.0.0.1
FINANCE_CONTROL_HTTP_PORT=8780

# ---------------------------------------------------------------------------
# Bank portal fetch (Selenium) — used by pipeline portal download steps
# ---------------------------------------------------------------------------
bank_username=
bank_password=

# Optional: additional institution logins if your setup uses them
# credit_username=
# credit_last6=
# credit_password=
# max_username=
# max_password=

# ---------------------------------------------------------------------------
# Google Sheets API — path to service account JSON and target spreadsheet
# ---------------------------------------------------------------------------
# Windows-style path example: data\static\your-project-abcdef.json
# POSIX example: data/static/your-project-abcdef.json
GOOGLE_API_USER=data/static/your-service-account.json
GOOGLE_WORKSHEET_ID=

# ---------------------------------------------------------------------------
# Sheet tab titles (optional overrides)
# ---------------------------------------------------------------------------
# FINANCE_TOTALS_SHEET_NAME=Totals
# FINANCE_DESKTOP_HOLDINGS_SHEET=
# FINANCE_DESKTOP_TOTALS_SHEET=

# ---------------------------------------------------------------------------
# Pipeline & Selenium debugging (optional)
# ---------------------------------------------------------------------------
# Mirror legacy cleaned CSVs under pipeline dirs for inspection.
# PIPELINE_DEBUG_DUMP=0

# Verbose Selenium steps; pause after each flow_debug_pause (1/true/yes).
# FINANCE_SELENIUM_DEBUG=0
# FINANCE_SELENIUM_PAUSE=0

# ---------------------------------------------------------------------------
# Dev helpers (optional)
# ---------------------------------------------------------------------------
# Python executable for web_control_restart.py when not using default venv discovery.
# FINANCE_PYTHON_EXE=
